# --- Database ---
# SQLite for local dev; swap to PostgreSQL with zero code changes:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/finaudit
DATABASE_URL=sqlite:///./finaudit.db

# --- LLM provider: "ollama" (local, free) or "gemini" (hosted, for deployment) ---
LLM_PROVIDER=ollama

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# --- Frontend ---
# Set in frontend/.env (or Vercel env vars): where the React app finds the API
# VITE_API_URL=http://localhost:8000
